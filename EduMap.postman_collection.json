        {
          "name": "Add School - Valid 1",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/addSchool" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ryan International School\",\n  \"address\": \"Sector 21, Dwarka, New Delhi\",\n  \"latitude\": 28.5921,\n  \"longitude\": 77.0460\n}"
            },
            "description": "Valid input — should return 201."
          },
          "response": [
            {
              "name": "201 - School Added",
              "status": "Created",
              "code": 201,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"success\": true,\n  \"message\": \"School added successfully.\"\n}"
            }
