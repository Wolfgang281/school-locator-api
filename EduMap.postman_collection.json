    {
      "name": "List Schools",
      "description": "All test cases for GET /listSchools",
      "item": [
        {
          "name": "List Schools - New Delhi",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/listSchools?latitude=28.6139&longitude=77.2090",
              "host": ["{{base_url}}"],
              "path": ["listSchools"],
              "query": [
                {
                  "key": "latitude",
                  "value": "28.6139",
                  "description": "User latitude (New Delhi)"
                },
                {
                  "key": "longitude",
                  "value": "77.2090",
                  "description": "User longitude (New Delhi)"
                }
              ]
            },
            "description": "Valid coordinates — returns schools sorted by distance from New Delhi."
          },
          "response": [
            {
              "name": "200 - Schools Fetched",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"success\": true,\n  \"message\": \"Schools fetched successfully.\",\n  \"data\": [\n    {\n      \"id\": 3,\n      \"name\": \"St. Columba's School\",\n      \"address\": \"Ashok Place, New Delhi\",\n      \"latitude\": 28.6353,\n      \"longitude\": 77.2010,\n      \"distance\": 2.64\n    },\n    {\n      \"id\": 2,\n      \"name\": \"Kendriya Vidyalaya\",\n      \"address\": \"IIT Campus, Hauz Khas, New Delhi\",\n      \"latitude\": 28.5459,\n      \"longitude\": 77.1926,\n      \"distance\": 7.72\n    }\n  ]\n}"
            }
          ]
        },
