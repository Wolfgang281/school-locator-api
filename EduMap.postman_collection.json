{
  "info": {
    "name": "EduMap - School Management API",
    "description": "Complete API collection for EduMap School Management System.\n\nBase URL: Change the `base_url` variable to your deployed URL.\n\nAPIs:\n- POST /addSchool — Add a new school\n- GET /listSchools — List schools sorted by proximity\n\nDeveloped with Node.js, Express.js, MySQL.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "description": "https://school-locator-api-eesr.onrender.com"
    }
  ],
  "item": [
